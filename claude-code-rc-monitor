#!/usr/bin/env python3
"""
claude-code-rc-monitor — Keep a Claude Code /rc session alive.

Usage:
  claude-code-rc-monitor <name> [--tmux | --pid PID] [--timeout-loop DURATION]
                                [--serve [IP:]PORT]
  claude-code-rc-monitor --list-pids
  claude-code-rc-monitor --help

Arguments:
  <name>                   Remote control name (required unless --list-pids).

Options:
  --tmux                   Find the single Claude Code instance in the current
                           tmux session and send /rc there. This is the default
                           when neither --tmux nor --pid is given.
  --pid PID                Target a specific Claude PID. Its enclosing tmux pane
                           is located automatically and used to send keys.
  --list-pids              List every Claude PID on this machine. For each PID
                           that lives inside a tmux pane, show the tmux session
                           (and window.pane). Then exit.
  --timeout-loop DURATION  Refresh interval. Bare numbers are seconds; suffix
                           'm' for minutes or 'h' for hours (e.g. 3600, 30m, 1h).
                           Default: 3600 (one hour). When --serve is used, the
                           timeout is disabled unless this flag is given
                           explicitly.
  --serve [IP:]PORT        Start a tiny HTTP server with a "start rc" button.
                           If IP is omitted, binds to 127.0.0.1. A random token
                           is generated at startup; the full URL (including the
                           token as '?t=...') is printed to stdout. GET / and
                           POST /start both require the token.
  -h, --help               Show this help and exit.

Behaviour:
  Sends /rc <name> to the target Claude pane, then waits up to the timeout.
  On timeout, Enter on stdin, SIGUSR1/SIGHUP, or a /start POST from the web
  UI, it disconnects and restarts /rc. Press Ctrl+C to quit.
"""

import argparse
import http.server
import json
import os
import secrets
import select
import signal
import socketserver
import subprocess
import sys
import threading
import time
import urllib.parse


DEFAULT_TIMEOUT = 3600  # 1 hour


def log(msg):
    ts = time.strftime("%H:%M:%S")
    print(f"[{ts}] {msg}", flush=True)


def die(msg):
    log(f"Error: {msg}")
    sys.exit(1)


def run_cmd(args):
    """Run a command as a list of args (no shell). Return (stdout, returncode)."""
    r = subprocess.run(args, capture_output=True, text=True)
    return r.stdout.strip(), r.returncode


# --- Duration parsing ---

def parse_duration(s):
    """Parse a duration string into seconds.

    Accepts bare seconds ('3600'), explicit seconds ('3600s'),
    minutes ('30m'), or hours ('1h'). Case-insensitive.
    """
    if s is None:
        raise ValueError("missing duration")
    s = str(s).strip().lower()
    if not s:
        raise ValueError("empty duration")

    suffix_mult = {"s": 1, "m": 60, "h": 3600}
    mult = 1
    num = s
    if s[-1] in suffix_mult:
        mult = suffix_mult[s[-1]]
        num = s[:-1]

    try:
        value = float(num)
    except ValueError:
        raise ValueError(f"not a number: {s!r}")

    secs = int(value * mult)
    if secs <= 0:
        raise ValueError(f"must be positive: {s!r}")
    return secs


# --- Process tree helpers ---

def _is_claude_command(cmd):
    """Check if a command string is a claude process.

    Matches 'claude', 'claude --flags', '/path/to/claude', etc.
    """
    exe = cmd.split()[0] if cmd.split() else ""
    basename = os.path.basename(exe)
    return basename == "claude"


def _read_ps():
    """Return (ppid_map, cmd_map, children_map) from `ps -eo pid,ppid,command`."""
    ps_out, _ = run_cmd(["ps", "-eo", "pid,ppid,command"])
    ppid_map = {}
    cmd_map = {}
    children_map = {}
    for line in ps_out.splitlines():
        parts = line.split(None, 2)
        if len(parts) < 3:
            continue
        pid, ppid, cmd = parts
        if pid == "PID":
            continue
        ppid_map[pid] = ppid
        cmd_map[pid] = cmd
        children_map.setdefault(ppid, []).append(pid)
    return ppid_map, cmd_map, children_map


def _get_descendants(pid, children_map):
    """Return all descendant PIDs of the given pid (breadth-first)."""
    descendants = []
    queue = list(children_map.get(pid, []))
    while queue:
        child = queue.pop(0)
        descendants.append(child)
        queue.extend(children_map.get(child, []))
    return descendants


# --- tmux helpers ---

def _tmux_available():
    _, rc = run_cmd(["tmux", "has-session"])
    # rc 0 if a session exists; non-zero otherwise (tmux may still be installed).
    # Use `tmux ls` exit code as a softer check.
    _, rc2 = run_cmd(["tmux", "ls"])
    return rc == 0 or rc2 == 0


def get_tmux_session():
    out, rc = run_cmd(["tmux", "display-message", "-p", "#{session_name}"])
    if rc != 0:
        die("Not running inside a tmux session")
    return out


def _list_all_panes():
    """List all tmux panes across all sessions.

    Returns dict: shell_pid -> (session_name, "W.P").
    Empty dict if tmux unavailable or no sessions.
    """
    out, rc = run_cmd([
        "tmux", "list-panes", "-a",
        "-F", "#{session_name}\t#{window_index}.#{pane_index}\t#{pane_pid}",
    ])
    panes = {}
    if rc != 0:
        return panes
    for line in out.splitlines():
        parts = line.split("\t")
        if len(parts) == 3:
            sess, pane_id, shell_pid = parts
            panes[shell_pid] = (sess, pane_id)
    return panes


def find_claude_panes(session):
    """Find panes in the given session whose shell has a claude descendant.

    Returns a list of (tmux_target, claude_pid) tuples.
    """
    out, rc = run_cmd([
        "tmux", "list-panes", "-t", session, "-s",
        "-F", "#{window_index}.#{pane_index} #{pane_pid}",
    ])
    if rc != 0:
        die(f"Cannot list panes for tmux session {session!r}")

    shell_pids = {}
    for line in out.splitlines():
        parts = line.split()
        if len(parts) == 2:
            pane_id, shell_pid = parts
            shell_pids[shell_pid] = f"{session}:{pane_id}"

    if not shell_pids:
        return []

    _, cmd_map, children_map = _read_ps()

    claude_panes = []
    for shell_pid, tmux_target in shell_pids.items():
        for desc_pid in _get_descendants(shell_pid, children_map):
            if desc_pid in cmd_map and _is_claude_command(cmd_map[desc_pid]):
                claude_panes.append((tmux_target, desc_pid))

    return claude_panes


def find_pane_for_pid(pid):
    """Given a claude PID, walk up its ppid chain to find the enclosing tmux
    pane. Returns "session:W.P" or None.
    """
    ppid_map, _, _ = _read_ps()
    pane_map = _list_all_panes()

    cur = str(pid)
    seen = set()
    while cur in ppid_map and cur not in seen:
        seen.add(cur)
        if cur in pane_map:
            sess, pane_id = pane_map[cur]
            return f"{sess}:{pane_id}"
        cur = ppid_map[cur]
    # Also handle the case where the PID itself is a pane shell (unlikely for claude)
    if str(pid) in pane_map:
        sess, pane_id = pane_map[str(pid)]
        return f"{sess}:{pane_id}"
    return None


def list_all_claude_pids():
    """List every claude process. Returns list of (pid, cmd, tmux_info)
    where tmux_info is "session:W.P" or None.
    """
    ppid_map, cmd_map, _ = _read_ps()
    pane_map = _list_all_panes()

    claude_pids = [pid for pid, cmd in cmd_map.items() if _is_claude_command(cmd)]
    claude_pids.sort(key=lambda p: int(p))

    results = []
    for pid in claude_pids:
        cur = pid
        seen = set()
        tmux_info = None
        while cur in ppid_map and cur not in seen:
            seen.add(cur)
            if cur in pane_map:
                sess, pane_id = pane_map[cur]
                tmux_info = f"{sess}:{pane_id}"
                break
            cur = ppid_map[cur]
        results.append((pid, cmd_map[pid], tmux_info))
    return results


# --- Pane I/O ---

def tmux_send_keys(target, *keys):
    subprocess.run(
        ["tmux", "send-keys", "-t", target] + list(keys),
        capture_output=True, text=True,
    )


def capture_pane(target):
    out, _ = run_cmd(["tmux", "capture-pane", "-t", target, "-p"])
    return out


def is_thinking(target):
    """Check if Claude is actively thinking by looking for the spinner line
    above the prompt separator (───).

    The TUI layout when thinking:
        ✳ Grooving… (34s · ↓ 600 tokens)
          ⎿  Tip: ...               (optional)
                                     (blank)
        ──────────────────────────
        ❯
        ──────────────────────────
        ⏵⏵ accept edits on ...

    When idle, the line above the separator is regular content (no …).
    """
    pane_text = capture_pane(target)
    lines = pane_text.splitlines()

    for i, line in enumerate(lines):
        stripped = line.strip()
        if stripped.startswith("❯"):
            for j in range(i - 2, max(i - 8, -1), -1):
                candidate = lines[j].strip()
                if not candidate or candidate.startswith("─"):
                    continue
                if candidate.startswith("⎿"):
                    continue
                return "…" in candidate
            break
    return False


def wait_for_idle(target, timeout=300):
    """Wait until Claude is idle (not thinking). Returns True if idle, False on timeout."""
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if not is_thinking(target):
            return True
        remaining = int(deadline - time.monotonic())
        log(f"Claude is thinking — waiting for idle ({remaining}s remaining)")
        time.sleep(5)
    return False


def restart_rc(target, name):
    """Disconnect any active /rc and start a new one with the given name."""
    if not wait_for_idle(target):
        log("Warning: timed out waiting for Claude to become idle, proceeding anyway")

    tmux_send_keys(target, "Escape")
    time.sleep(0.3)

    tmux_send_keys(target, "/remote-control", "Enter")
    time.sleep(2)

    pane_text = capture_pane(target)

    if "Disconnect this session" in pane_text:
        log("RC active — disconnecting via menu")
        tmux_send_keys(target, "Up")
        time.sleep(0.3)
        tmux_send_keys(target, "Up")
        time.sleep(0.3)
        tmux_send_keys(target, "Enter")
        time.sleep(1)

        pane_text = capture_pane(target)
        if "Remote Control disconnected" in pane_text:
            log("Disconnect confirmed")
        else:
            log("Warning: disconnect not confirmed in pane output")
    elif "Remote Control connecting" in pane_text or "Remote Control active" in pane_text:
        log("RC was not active — /remote-control started a session, disconnecting it")
        tmux_send_keys(target, "/remote-control", "Enter")
        time.sleep(2)
        pane_text = capture_pane(target)
        if "Disconnect this session" in pane_text:
            tmux_send_keys(target, "Up")
            time.sleep(0.3)
            tmux_send_keys(target, "Up")
            time.sleep(0.3)
            tmux_send_keys(target, "Enter")
            time.sleep(1)
    else:
        log("Warning: unexpected pane state after /remote-control")

    log(f"Starting /rc {name}")
    tmux_send_keys(target, f"/rc {name}", "Enter")
    time.sleep(2)

    pane_text = capture_pane(target)
    if "Remote Control connecting" in pane_text or "Remote Control active" in pane_text:
        log("RC session started successfully")
    else:
        log("Warning: RC session start not confirmed in pane output")


# --- Signal handling & loop ---

_wakeup = False


def _on_signal(signum, frame):
    global _wakeup
    _wakeup = True


def wait_for_trigger(timeout):
    """Block until a trigger fires. Return a string reason.

    If `timeout` is None, waits indefinitely (only a trigger will wake it).
    Triggers: Enter on stdin, SIGUSR1/SIGHUP, or a web POST /start (which
    sets _wakeup). When `timeout` is a positive number and elapses first,
    returns "timeout".
    """
    global _wakeup
    _wakeup = False

    deadline = None if timeout is None else time.monotonic() + timeout
    while True:
        if _wakeup:
            return "signal"
        if deadline is not None:
            remaining = deadline - time.monotonic()
            if remaining <= 0:
                return "timeout"
            poll = min(remaining, 1.0)
        else:
            poll = 1.0
        try:
            ready, _, _ = select.select([sys.stdin], [], [], poll)
            if ready:
                sys.stdin.readline()
                return "enter"
        except InterruptedError:
            if _wakeup:
                return "signal"


def check_claude_alive(pid):
    try:
        os.kill(int(pid), 0)
        return True
    except (OSError, ValueError):
        return False


# --- Modes ---

def cmd_list_pids():
    rows = list_all_claude_pids()
    if not rows:
        print("No Claude Code processes found.")
        return 0
    width = max(len(pid) for pid, _, _ in rows)
    for pid, cmd, tmux_info in rows:
        loc = tmux_info if tmux_info else "-"
        print(f"{pid:>{width}}  {loc:<30}  {cmd}")
    return 0


def resolve_target_tmux():
    session = get_tmux_session()
    panes = find_claude_panes(session)
    if len(panes) == 0:
        die("No Claude Code instance found in this tmux session")
    if len(panes) > 1:
        targets = ", ".join(f"{t} (pid {p})" for t, p in panes)
        die(f"Found {len(panes)} Claude instances — expected 1: {targets}")
    return panes[0]  # (target, pid)


def resolve_target_pid(pid):
    if not check_claude_alive(pid):
        die(f"PID {pid} is not running")
    target = find_pane_for_pid(pid)
    if not target:
        die(f"Could not find a tmux pane containing PID {pid}")
    return target, str(pid)


def run_loop(initial_target, initial_pid, name, timeout, rescan_tmux_session):
    """Main refresh loop.

    If rescan_tmux_session is set, rescans that session each iteration so a
    restarted Claude is picked up. Otherwise reuses the fixed target/pid.
    """
    signal.signal(signal.SIGUSR1, _on_signal)
    signal.signal(signal.SIGHUP, _on_signal)

    log(
        f"RC Monitor | target: {initial_target} | claude pid: {initial_pid} | "
        f"name: {name} | monitor pid: {os.getpid()}"
    )
    if timeout is None:
        log("Timeout disabled. Enter/SIGUSR1/SIGHUP/web-trigger to refresh. Ctrl+C to quit.")
    else:
        mins = timeout / 60
        log(
            f"Refresh every {timeout}s ({mins:g}m). "
            "Enter/SIGUSR1/SIGHUP/web-trigger to refresh. Ctrl+C to quit."
        )

    target, pid = initial_target, initial_pid
    while True:
        if rescan_tmux_session:
            panes = find_claude_panes(rescan_tmux_session)
            if len(panes) == 0:
                die("No Claude Code instance found in this tmux session")
            if len(panes) > 1:
                targets = ", ".join(f"{t} (pid {p})" for t, p in panes)
                die(f"Found {len(panes)} Claude instances — expected 1: {targets}")
            target, pid = panes[0]

        log(f"Sending /rc {name} -> {target} (pid {pid})")
        restart_rc(target, name)

        reason = wait_for_trigger(timeout)

        if not check_claude_alive(pid):
            log(f"Claude {pid} exited, rescanning...")
            if not rescan_tmux_session:
                die("Targeted PID has exited; nothing to refresh")
        else:
            log(f"Refreshing ({reason})")


# --- Web UI ---

_AUTH_TOKEN = None
_SERVE_INFO = {"target": "", "pid": "", "name": ""}

_HTML_TEMPLATE = """<!doctype html>
