def parse_serve_spec(spec):
    """Parse '[IP:]PORT' into (host, port).

    Bare port → 127.0.0.1. ':PORT' → 0.0.0.0. '[::1]:PORT' → IPv6.
    """
    spec = spec.strip()
    if not spec:
        raise ValueError("empty --serve value")
    if spec.startswith("["):
        host_end = spec.find("]")
        if host_end < 0 or not spec[host_end + 1 :].startswith(":"):
            raise ValueError(f"expected [IPv6]:PORT, got {spec!r}")
        host = spec[1:host_end]
        port = spec[host_end + 2 :]
    elif ":" in spec:
        host, _, port = spec.rpartition(":")
        if not host:
            host = "0.0.0.0"
    else:
        host, port = "127.0.0.1", spec
    try:
        port_i = int(port)
    except ValueError:
        raise ValueError(f"invalid port in {spec!r}")
    if not (0 < port_i < 65536):
        raise ValueError(f"port out of range in {spec!r}")
    return host, port_i


class _RCHandler(http.server.BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        log(f"http {self.address_string()} {fmt % args}")

    def _reply(self, code, body, ctype="text/plain; charset=utf-8"):
        data = body.encode("utf-8") if isinstance(body, str) else body
        self.send_response(code)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(data)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(data)

    def _query_token(self):
        q = urllib.parse.urlparse(self.path).query
        return urllib.parse.parse_qs(q).get("t", [None])[0]

    def do_GET(self):
        path = urllib.parse.urlparse(self.path).path
        if path != "/":
            return self._reply(404, "not found\n")
        if self._query_token() != _AUTH_TOKEN:
            return self._reply(401, "unauthorized\n")
        html = _HTML_TEMPLATE.format(
            target=_SERVE_INFO["target"],
            pid=_SERVE_INFO["pid"],
            name=_SERVE_INFO["name"],
            token_json=json.dumps(_AUTH_TOKEN),
        )
        return self._reply(200, html, "text/html; charset=utf-8")

    def do_POST(self):
        path = urllib.parse.urlparse(self.path).path
        if path != "/start":
            return self._reply(404, "not found\n")
        if self.headers.get("X-Auth-Token") != _AUTH_TOKEN:
            return self._reply(401, "unauthorized\n")
        global _wakeup
        _wakeup = True
        return self._reply(200, "triggered\n")


class _ThreadingServer(socketserver.ThreadingMixIn, http.server.HTTPServer):
    daemon_threads = True
    allow_reuse_address = True


def start_web_server(host, port, token, target, pid, name):
    """Bind and start the HTTP server on a daemon thread. Returns the URL."""
    global _AUTH_TOKEN
    _AUTH_TOKEN = token
    _SERVE_INFO["target"] = str(target)
    _SERVE_INFO["pid"] = str(pid)
    _SERVE_INFO["name"] = str(name)

    server = _ThreadingServer((host, port), _RCHandler)
    t = threading.Thread(target=server.serve_forever, name="rc-http", daemon=True)
    t.start()

    # Format URL; bracket IPv6 literals.
    display_host = f"[{host}]" if ":" in host else host
    if host in ("0.0.0.0", "::"):
        display_host = "localhost"
    return f"http://{display_host}:{port}/?t={token}"


# --- Entry point ---

def _print_help_and_exit(code=0):
    print(__doc__.strip())
    sys.exit(code)


def main():
    # Bare invocation: show help.
    if len(sys.argv) == 1:
        _print_help_and_exit(0)

    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("name", nargs="?")
    parser.add_argument("--tmux", action="store_true")
    parser.add_argument("--pid", type=int)
    parser.add_argument("--list-pids", action="store_true", dest="list_pids")
    parser.add_argument("--timeout-loop", default=None, dest="timeout_loop")
    parser.add_argument("--serve", default=None)
    parser.add_argument("-h", "--help", action="store_true")

    try:
        args = parser.parse_args()
    except SystemExit:
        # argparse already wrote an error message
        raise

    if args.help:
        _print_help_and_exit(0)

    if args.list_pids:
        sys.exit(cmd_list_pids())

    if args.tmux and args.pid is not None:
        die("--tmux and --pid are mutually exclusive")

    if not args.name:
        log("Error: remote control name is required (first positional argument).")
        print()
        _print_help_and_exit(2)

    # Timeout: if --serve, the timeout is disabled unless the user passes
    # --timeout-loop explicitly. Otherwise default to DEFAULT_TIMEOUT.
    if args.timeout_loop is not None:
        try:
            timeout = parse_duration(args.timeout_loop)
        except ValueError as e:
            die(f"Invalid --timeout-loop value: {e}")
    elif args.serve is not None:
        timeout = None
    else:
        timeout = DEFAULT_TIMEOUT

    name = args.name

    if args.pid is not None:
        target, pid = resolve_target_pid(args.pid)
        rescan_session = None
    else:
        # --tmux explicit, or default behaviour
        target, pid = resolve_target_tmux()
        rescan_session = get_tmux_session()

    if args.serve is not None:
        try:
            host, port = parse_serve_spec(args.serve)
        except ValueError as e:
            die(f"Invalid --serve value: {e}")
        token = secrets.token_urlsafe(24)
        try:
            url = start_web_server(host, port, token, target, pid, name)
        except OSError as e:
            die(f"Cannot start web server on {host}:{port}: {e}")
        log(f"Web UI: {url}")
        if host not in ("127.0.0.1", "::1", "localhost"):
            log("Warning: bound to a non-loopback address — anyone on the network "
                "who learns the token URL can trigger /rc restarts.")

    run_loop(target, pid, name, timeout, rescan_session)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\nStopped.")
